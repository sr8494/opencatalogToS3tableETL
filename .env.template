# AWS Configuration
AWS_PROFILE=your-aws-profile
AWS_REGION=us-east-2
AWS_ACCOUNT_ID=123456789012

# S3 Buckets - Separate buckets for Goal 1 and Goal 2
S3_BUCKET_DAILY=your-bucket-name-daily          # For Goal 1 (Snowflake Open Catalog)

# S3 Tables Configuration - Goal 2 (Managed Iceberg table storage)
S3_TABLES_BUCKET_NAME=your-s3-tables-bucket  # S3 Tables bucket name
S3_TABLES_BUCKET_ARN=arn:aws:s3tables:us-east-2:123456789012:bucket/your-s3-tables-bucket

# IAM Roles - Separate roles for different services
IAM_ROLE_ARN=arn:aws:iam::123456789012:role/your-snowflake-role  # For Snowflake Open Catalog
GLUE_IAM_ROLE_ARN=arn:aws:iam::123456789012:role/your-glue-lakeformation-role  # For Glue + LakeFormation
EXTERNAL_ID=your-external-id

# Snowflake Open Catalog Configuration (OAuth Client Credentials)
SNOWFLAKE_ACCOUNT=your_account
SNOWFLAKE_CLIENT_ID=your_client_id_here
SNOWFLAKE_CLIENT_SECRET=your_client_secret_here
SNOWFLAKE_CATALOG_NAME=your-catalog-name
SNOWFLAKE_CATALOG_URI=https://your-account-locator.region.aws.snowflakecomputing.com/polaris/api/catalog

# Table Configuration - Goal 1 (Snowflake Open Catalog + Daily Partitioning)
DAILY_TABLE_NAMESPACE=demo_db
DAILY_TABLE_NAME=events_daily

# Table Configuration - Goal 2 (AWS Glue + LakeFormation + Hourly Partitioning)
HOURLY_TABLE_DATABASE=icelake_hourly_db
HOURLY_TABLE_NAME=events_hourly

# State Management
STATE_FILE_PATH=state/etl_state.json
